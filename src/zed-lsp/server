#!/usr/bin/env node

const { contains, findRefs } = require('./scanner')

const documents = new Map()
const purlCache = new Map()
const pendingPurls = new Set()
let serverSettings = {}
let queueFlushTimer
let input = Buffer.alloc(0)

process.stdin.on('data', chunk => {
  input = Buffer.concat([input, chunk])
  for (;;) {
    const headerEnd = input.indexOf('\r\n\r\n')
    if (headerEnd < 0) {
      return
    }
    const header = input.subarray(0, headerEnd).toString('utf8')
    const contentLengthMatch = /^Content-Length: (\d+)$/im.exec(header)
    if (!contentLengthMatch) {
      input = input.subarray(headerEnd + 4)
      continue
    }
    const length = Number(contentLengthMatch[1])
    const bodyStart = headerEnd + 4
    const bodyEnd = bodyStart + length
    if (input.length < bodyEnd) {
      return
    }
    const body = input.subarray(bodyStart, bodyEnd).toString('utf8')
    input = input.subarray(bodyEnd)
    handleMessage(JSON.parse(body)).catch(err =>
      log(`handler error: ${err.stack ?? err}`),
    )
  }
})

async function handleMessage(message) {
  if (message.method === 'initialize') {
    serverSettings = mergeSettings(
      serverSettings,
      message.params?.initializationOptions,
    )
    respond(message.id, {
      capabilities: {
        hoverProvider: true,
        textDocumentSync: 1,
      },
      serverInfo: {
        name: 'Socket Security',
        version: '2.0.3',
      },
    })
    return
  }
  if (message.method === 'workspace/didChangeConfiguration') {
    serverSettings = mergeSettings(serverSettings, message.params?.settings)
    purlCache.clear()
    for (const doc of documents.values()) {
      await analyze(doc.uri)
    }
    return
  }
  if (message.method === 'shutdown') {
    respond(message.id, null)
    return
  }
  if (message.method === 'textDocument/didOpen') {
    const doc = message.params.textDocument
    documents.set(doc.uri, {
      uri: doc.uri,
      languageId: doc.languageId,
      version: doc.version,
      text: doc.text,
      refs: [],
    })
    await analyze(doc.uri)
    return
  }
  if (message.method === 'textDocument/didChange') {
    const uri = message.params.textDocument.uri
    const doc = documents.get(uri)
    if (!doc) {
      return
    }
    const change = message.params.contentChanges.at(-1)
    if (!change || typeof change.text !== 'string') {
      return
    }
    doc.text = change.text
    doc.version = message.params.textDocument.version
    await analyze(uri)
    return
  }
  if (message.method === 'textDocument/didClose') {
    const uri = message.params.textDocument.uri
    documents.delete(uri)
    notify('textDocument/publishDiagnostics', {
      uri,
      diagnostics: [],
    })
    return
  }
  if (message.method === 'textDocument/hover') {
    respond(
      message.id,
      hover(message.params.textDocument.uri, message.params.position),
    )
  }
}

async function analyze(uri) {
  const doc = documents.get(uri)
  if (!doc) {
    return
  }
  doc.refs = findRefs(doc)
  for (let i = 0, { length } = doc.refs; i < length; i += 1) {
    queuePurl(doc.refs[i].purl)
  }
  await flushPurlsSoon()
  publishDiagnostics(doc)
}

function publishDiagnostics(doc) {
  const diagnostics = []
  for (let i = 0, { length } = doc.refs; i < length; i += 1) {
    const ref = doc.refs[i]
    const data = purlCache.get(ref.purl)
    const packageData = data?.pkgData
    if (!packageData) {
      continue
    }
    const summary = alertSummary(packageData.alerts ?? [])
    if (summary.types.length === 0) {
      continue
    }
    const score = Math.round((packageData.score?.overall ?? 0) * 100)
    const packageName = displayPackageName(packageData, ref.purl)
    const topTypes = summary.types
      .slice(0, 3)
      .map(type => alertTitle(type))
      .join(', ')
    const remaining =
      summary.types.length > 3 ? `, +${summary.types.length - 3} more` : ''
    diagnostics.push({
      range: ref.range,
      severity: summary.diagnosticSeverity,
      source: 'Socket Security',
      code: ref.purl,
      message: `${packageName}: Socket score ${score}/100, ${summary.label} alert${summary.total === 1 ? '' : 's'} (${topTypes}${remaining})`,
      data: {
        purl: ref.purl,
      },
    })
  }
  notify('textDocument/publishDiagnostics', {
    uri: doc.uri,
    diagnostics,
  })
}

function hover(uri, position) {
  const doc = documents.get(uri)
  if (!doc) {
    return null
  }
  for (let i = 0, { length } = doc.refs; i < length; i += 1) {
    const ref = doc.refs[i]
    if (!contains(ref.range, position)) {
      continue
    }
    return {
      range: ref.range,
      contents: {
        kind: 'markdown',
        value: hoverMarkdown(ref.purl),
      },
    }
  }
  return null
}

function hoverMarkdown(purl) {
  const data = purlCache.get(purl)
  if (!data) {
    return `Socket Security for [${purl}](https://socket.dev/${purl})\n\nFetching package data.`
  }
  if (data.error) {
    return `Socket Security for [${purl}](https://socket.dev/${purl})\n\n${data.error}`
  }
  const packageData = data.pkgData
  if (!packageData) {
    return `Socket Security for [${purl}](https://socket.dev/${purl})`
  }
  const link = packageLink(purl, packageData)
  const packageName = displayPackageName(packageData, purl)
  const score = Math.round((packageData.score?.overall ?? 0) * 100)
  const summary = alertSummary(packageData.alerts ?? [])
  const rows = [
    `### [${packageName}](${link})`,
    '',
    `**Socket score:** ${score}/100`,
  ]
  const metadata = packageMetadata(packageData)
  if (metadata.length > 0) {
    rows.push('', metadata.join(' · '))
  }
  rows.push('', scoreTable(packageData.score))
  if (summary.total > 0) {
    rows.push(
      '',
      `**Alerts:** ${summary.total} total · ${summary.byAction.error} error · ${summary.byAction.warn} warn · ${summary.byAction.monitor} monitor · ${summary.byAction.ignore} ignored`,
    )
  }
  const alerts = sortedAlerts(packageData.alerts ?? [])
  if (alerts.length > 0) {
    rows.push('', '| status | alert | details |', '| --- | --- | --- |')
    const seen = new Set()
    for (let i = 0, { length } = alerts; i < length; i += 1) {
      const alert = alerts[i]
      const dedupeKey = `${alert.action}:${alert.type}`
      if (seen.has(dedupeKey)) {
        continue
      }
      seen.add(dedupeKey)
      rows.push(
        `| ${actionLabel(alert.action)} | ${alertTitle(alert.type)} | ${alertDetails(alert, packageData)} |`,
      )
    }
  }
  return rows.join('\n')
}

function actionLabel(action) {
  return {
    error: 'Error',
    ignore: 'Info',
    monitor: 'Monitor',
    warn: 'Warn',
  }[action] ?? action
}

function alertDetails(alert, packageData) {
  const details = []
  const alternatePackage = alert.props?.alternatePackage
  if (alternatePackage) {
    details.push(
      `Possible intended package: [${alternatePackage}](${alternatePackageLink(alternatePackage, packageData)})`,
    )
  }
  if (alert.props?.lastPublish) {
    details.push(`Last published ${formatDate(alert.props.lastPublish)}`)
  }
  if (alert.props?.note) {
    details.push(String(alert.props.note).replaceAll(/\r?\n/g, '<br>'))
  }
  if (alert.severity) {
    details.push(`Severity: ${alert.severity}`)
  }
  return details.length > 0 ? details.join('<br>') : alertDescription(alert.type)
}

function alertDescription(type) {
  return {
    envVars: 'Package accesses environment variables.',
    fileSystem: 'Package accesses the local filesystem.',
    installScripts: 'Package runs install-time scripts.',
    networkAccess: 'Package makes network requests.',
    shellAccess: 'Package can spawn shell commands.',
    telemetry: 'Package may collect telemetry.',
    urlStrings: 'Package contains URL strings.',
  }[type] ?? 'See Socket package page for details.'
}

function alertSummary(alerts) {
  const byAction = {
    error: 0,
    ignore: 0,
    monitor: 0,
    warn: 0,
  }
  const types = []
  let diagnosticSeverity = 4
  for (let i = 0, { length } = alerts; i < length; i += 1) {
    const alert = alerts[i]
    if (alert.action in byAction) {
      byAction[alert.action] += 1
    }
    if (alert.action === 'error') {
      diagnosticSeverity = 1
    } else if (alert.action === 'warn' && diagnosticSeverity > 2) {
      diagnosticSeverity = 2
    } else if (alert.action === 'monitor' && diagnosticSeverity > 3) {
      diagnosticSeverity = 3
    }
    if (!types.includes(alert.type)) {
      types.push(alert.type)
    }
  }
  const label =
    byAction.error > 0
      ? 'error'
      : byAction.warn > 0
        ? 'warning'
        : byAction.monitor > 0
          ? 'monitor'
          : 'informational'
  return {
    byAction,
    diagnosticSeverity,
    label,
    total: alerts.length,
    types,
  }
}

function alertTitle(type) {
  return String(type)
    .replaceAll(/([a-z])([A-Z])/g, '$1 $2')
    .replaceAll(/[-_]+/g, ' ')
    .replace(/^./, char => char.toUpperCase())
}

function alternatePackageLink(name, packageData) {
  const type = packageData.type === 'golang' ? 'go' : packageData.type
  return `https://socket.dev/${type}/package/${name}`
}

function displayPackageName(packageData, purl) {
  const namespace = packageData.namespace ? `${packageData.namespace}/` : ''
  return packageData.name ? `${namespace}${packageData.name}` : purl
}

function formatDate(value) {
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) {
    return String(value)
  }
  return date.toLocaleDateString(undefined, {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  })
}

function packageMetadata(packageData) {
  const metadata = []
  if (packageData.type) {
    metadata.push(`**Ecosystem:** ${packageData.type}`)
  }
  if (packageData.version) {
    metadata.push(`**Version:** ${packageData.version}`)
  }
  if (packageData.license) {
    metadata.push(`**License:** ${packageData.license}`)
  }
  return metadata
}

function scoreTable(score) {
  if (!score) {
    return ''
  }
  const rows = [
    ['Overall', score.overall],
    ['Supply chain', score.supplyChain],
    ['Vulnerability', score.vulnerability],
    ['Maintenance', score.maintenance],
    ['Quality', score.quality],
    ['License', score.license],
  ].filter(([, value]) => typeof value === 'number')
  if (rows.length === 0) {
    return ''
  }
  return [
    '| score | value |',
    '| --- | ---: |',
    ...rows.map(([label, value]) => `| ${label} | ${Math.round(value * 100)}/100 |`),
  ].join('\n')
}

function sortedAlerts(alerts) {
  const actionRank = {
    error: 0,
    warn: 1,
    monitor: 2,
    ignore: 3,
  }
  return [...alerts].sort((a, b) => {
    const actionDelta = (actionRank[a.action] ?? 99) - (actionRank[b.action] ?? 99)
    if (actionDelta !== 0) {
      return actionDelta
    }
    return String(a.type).localeCompare(String(b.type))
  })
}

function packageLink(purl, packageData) {
  let type = packageData.type
  let version = `/overview/${packageData.version ?? 'latest'}`
  if (type === 'golang') {
    type = 'go'
    version = `?section=overview&version=${packageData.version ?? 'latest'}`
  }
  const namespace = packageData.namespace ? `${packageData.namespace}/` : ''
  return `https://socket.dev/${type}/package/${namespace}${packageData.name}${version}`
}

function queuePurl(purl) {
  if (!purlCache.has(purl)) {
    purlCache.set(purl, {
      pkgData: undefined,
      error: undefined,
    })
  }
  pendingPurls.add(purl)
}

function flushPurlsSoon() {
  if (queueFlushTimer) {
    return Promise.resolve()
  }
  return new Promise(resolve => {
    queueFlushTimer = setTimeout(async () => {
      queueFlushTimer = undefined
      await fetchPurls()
      for (const doc of documents.values()) {
        publishDiagnostics(doc)
      }
      resolve()
    }, 50)
  })
}

async function fetchPurls() {
  const purls = Array.from(pendingPurls)
  pendingPurls.clear()
  if (purls.length === 0) {
    return
  }
  const headers = {
    'content-type': 'application/json',
  }
  const token =
    configuredToken() ??
    process.env.SOCKET_API_TOKEN ??
    process.env.SOCKET_API_KEY ??
    process.env.SOCKET_SECURITY_API_TOKEN ??
    process.env.SOCKET_SECURITY_API_KEY
  if (token) {
    headers.authorization = `Bearer ${token}`
  }
  try {
    const res = await fetch(
      'https://api.socket.dev/v0/purl?alerts=true&compact=false',
      {
        method: 'POST',
        headers,
        body: JSON.stringify({
          components: purls.map(purl => ({ purl })),
        }),
      },
    )
    if (!res.ok || !res.body) {
      throw new Error(`Socket API returned ${res.status} ${res.statusText}`)
    }
    const found = new Set()
    const reader = res.body.getReader()
    const decoder = new TextDecoder()
    let chunk = ''
    for (;;) {
      const { done, value } = await reader.read()
      if (done) {
        break
      }
      chunk += decoder.decode(value, { stream: true })
      let newline
      while ((newline = chunk.indexOf('\n')) >= 0) {
        const line = chunk.slice(0, newline).trim()
        chunk = chunk.slice(newline + 1)
        if (!line) {
          continue
        }
        const pkgData = JSON.parse(line)
        found.add(pkgData.inputPurl)
        purlCache.set(pkgData.inputPurl, {
          pkgData,
          error: undefined,
        })
      }
    }
    for (let i = 0, { length } = purls; i < length; i += 1) {
      if (!found.has(purls[i])) {
        purlCache.set(purls[i], {
          pkgData: undefined,
          error: 'Package data was not found in Socket.',
        })
      }
    }
  } catch (err) {
    for (let i = 0, { length } = purls; i < length; i += 1) {
      purlCache.set(purls[i], {
        pkgData: undefined,
        error: `Unable to load Socket package data: ${err.message}`,
      })
    }
  }
}

function configuredToken() {
  for (const settings of [serverSettings, userSettings(), projectSettings()]) {
    const token =
      settings?.socket_api_token ??
      settings?.api_token ??
      settings?.context_servers?.['socket-security']?.settings?.socket_api_token ??
      settings?.context_servers?.['socket-security']?.settings?.api_token
    if (typeof token === 'string' && token.trim()) {
      return token.trim()
    }
  }
  return undefined
}

function mergeSettings(current, next) {
  if (!next || typeof next !== 'object') {
    return current
  }
  return {
    ...current,
    ...next,
  }
}

function projectSettings() {
  const doc = documents.values().next().value
  if (!doc?.uri?.startsWith('file://')) {
    return undefined
  }
  try {
    const filePath = decodeURIComponent(new URL(doc.uri).pathname)
    const segments = filePath.split('/').filter(Boolean)
    for (let i = segments.length - 1; i >= 0; i -= 1) {
      const candidate = `/${segments.slice(0, i).join('/')}/.zed/settings.json`
      if (require('node:fs').existsSync(candidate)) {
        return readJsonc(candidate)
      }
    }
  } catch {
    return undefined
  }
  return undefined
}

function userSettings() {
  const home = require('node:os').homedir()
  const paths = [
    process.env.XDG_CONFIG_HOME
      ? `${process.env.XDG_CONFIG_HOME}/zed/settings.json`
      : `${home}/.config/zed/settings.json`,
    `${home}/Library/Application Support/Zed/settings.json`,
  ]
  for (let i = 0, { length } = paths; i < length; i += 1) {
    const settings = readJsonc(paths[i])
    if (settings) {
      return settings
    }
  }
  return undefined
}

function readJsonc(filePath) {
  try {
    const fs = require('node:fs')
    if (!fs.existsSync(filePath)) {
      return undefined
    }
    return JSON.parse(stripJsonComments(fs.readFileSync(filePath, 'utf8')))
  } catch {
    return undefined
  }
}

function stripJsonComments(text) {
  return text
    .replaceAll(/\/\*[\s\S]*?\*\//g, '')
    .replaceAll(/(^|[^:])\/\/.*$/gm, '$1')
    .replaceAll(/,\s*([}\]])/g, '$1')
}

function respond(id, result) {
  send({
    jsonrpc: '2.0',
    id,
    result,
  })
}

function notify(method, params) {
  send({
    jsonrpc: '2.0',
    method,
    params,
  })
}

function send(message) {
  const body = JSON.stringify(message)
  process.stdout.write(
    `Content-Length: ${Buffer.byteLength(body, 'utf8')}\r\n\r\n${body}`,
  )
}

function log(message) {
  process.stderr.write(`[socket-security-lsp] ${message}\n`)
}
