{
  "extends": "./.config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["test/**/*.mts"],
  "exclude": ["**/.cache/**", "**/node_modules/**/*", "**/vendor/**/*"]
}
