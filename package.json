{
  "name": "zed-socket-security",
  "displayName": "Socket Security",
  "description": "Editor integration with Socket Security",
  "version": "2.0.3",
  "private": true,
  "preview": false,
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "tags": [
    "Code Analysis",
    "Code Quality",
    "JavaScript",
    "Python",
    "Security",
    "Static Code Analysis",
    "TypeScript"
  ],
  "keywords": [
    "Code Analysis",
    "Code Quality",
    "JavaScript",
    "Python",
    "Security",
    "Static Code Analysis",
    "TypeScript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=25.0.0"
  },
  "packageManager": "pnpm@11.1.3",
  "icon": "assets/socket-icon-brand-256.png",
  "type": "commonjs",
  "homepage": "https://socket.dev",
  "bugs": {
    "email": "support@socket.dev"
  },
  "scripts": {
    "build": "node zed-package",
    "check": "node scripts/check.mts",
    "check:paths": "node scripts/check-paths.mts",
    "clean": "node -e \"require('node:fs').rmSync('build',{recursive:true,force:true});require('node:fs').rmSync('target',{recursive:true,force:true})\"",
    "cover": "pnpm run test -- --coverage",
    "fix": "node scripts/fix.mts",
    "format": "oxfmt -c .config/oxfmtrc.json --write .",
    "format:check": "oxfmt -c .config/oxfmtrc.json --check .",
    "lint": "node scripts/lint.mts",
    "lockstep": "node scripts/lockstep.mts",
    "lockstep:emit-schema": "node scripts/lockstep-emit-schema.mts",
    "prepare": "node scripts/install-git-hooks.mts",
    "security": "node scripts/security.mts",
    "test": "node scripts/test.mts",
    "update": "node scripts/update.mts",
    "setup-security-tools": "node .claude/hooks/setup-security-tools/install.mts"
  },
  "dependencies": {
    "@socketsecurity/lib": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "@vitest/coverage-v8": "4.1.5",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "taze": "19.11.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "url": "https://github.com/0xgingi/zed-socket-security"
  }
}
